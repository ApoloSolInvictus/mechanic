OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=1400
ALLOWED_ORIGINS=https://pits.infiniti-ia.com

# Optional: enable when you want the backend to use OpenAI web search tools for fresher public info.
# OPENAI_ENABLE_WEB_SEARCH=true

# Optional visual search settings.
# Without Google keys, the backend falls back to Openverse/Wikimedia public image search.
IMAGE_SEARCH_ENABLED=true
IMAGE_SEARCH_PROVIDER=auto
IMAGE_SEARCH_COUNT=3
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# GOOGLE_IMAGE_RIGHTS=cc_publicdomain,cc_attribute,cc_sharealike
